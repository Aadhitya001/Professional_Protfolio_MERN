{
  "name": "professional-portfolio-mern",
  "version": "1.0.0",
  "description": "Full-stack MERN Professional Portfolio",
  "type": "module",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "seed": "cd backend && npm run seed",
    "build": "npm install --production=false --prefix frontend && npm run build --prefix frontend"
  },
  "dependencies": {
    "@vercel/functions": "^3.7.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
