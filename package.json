{
  "name": "professional-portfolio-mern",
  "version": "1.0.0",
  "description": "Full-stack MERN Professional Portfolio",
  "type": "module",
  "scripts": {
    "install-all": "npm.cmd install && cd backend && npm.cmd install && cd ../frontend && npm.cmd install",
    "backend": "cd backend && npm.cmd run dev",
    "frontend": "cd frontend && npm.cmd run dev",
    "dev": "concurrently \"npm.cmd run backend\" \"npm.cmd run frontend\"",
    "seed": "cd backend && npm.cmd run seed",
    "build": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
